{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "incremental": false,
    "types": ["@cloudflare/workers-types"],
    "lib": ["es2024", "dom", "dom.iterable"]
  },
  "include": [
    "src/index.ts",
    "src/router.ts",
    "src/types.ts",
    "src/lib/routeDrawer.ts",
    "src/utils/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
