{
  "name": "nomo/modules",
  "version": "1.0.0",
  "description": "BaseModule, autoloading, and dependency registry for nomo",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "nomo/features": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240603.0",
    "typescript": "^5.4.5",
    "tsup": "^8.1.0",
    "vitest": "^1.6.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2"
  }
}