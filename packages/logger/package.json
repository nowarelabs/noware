{
  "name": "nomo/logger",
  "version": "1.0.0",
  "description": "Logger for nomo applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external cloudflare:workers",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external cloudflare:workers"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250603.0",
    "@types/node": "^25.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0"
  }
}
