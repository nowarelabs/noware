{
  "name": "nomo/assets",
  "version": "1.0.0",
  "description": "Asset pipeline for nomo applications with HTMLRewriter support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --watch"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260203.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
