{
  "compilerOptions": {
    "outDir": "dist",
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "types": [
      "@cloudflare/workers-types"
    ],
    "baseUrl": ".",
    "paths": {
      "nomo/router": [
        "../router/src"
      ],
      "nomo/models": [
        "../models/src"
      ],
      "nomo/logger": [
        "../logger/src"
      ],
      "nomo/views": [
        "../views/src"
      ],
      "nomo/assets": [
        "../assets/src"
      ]
    }
  },
  "include": [
    "src/**/*"
  ]
}