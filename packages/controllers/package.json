    "noware-router": "workspace:*",
    "noware-views": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260203.0",
    "@types/http-status": "^1.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
