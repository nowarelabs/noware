{
  "name": "noware-controllers",
  "version": "1.0.0",
  "description": "Rails-adjacent controllers for nomo applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
