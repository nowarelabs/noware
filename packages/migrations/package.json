{
  "name": "nomo/migrations",
  "version": "1.0.0",
  "description": "Rails-adjacent migrations DSL for nomo applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/cli/index.ts --format cjs,esm --watch",
    "migrate": "tsx src/cli/index.ts",
    "test": "vitest run src/",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "nomo/logger": "workspace:*",
    "nomo/result": "workspace:*",
    "nomo/sql": "workspace:*",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "giget": "^3.2.0",
    "inflection": "^3.0.2",
    "ohash": "^2.0.11",
    "pathe": "^2.0.3",
    "scule": "^1.3.0",
    "zod": "^4.3.6"
  }
}
