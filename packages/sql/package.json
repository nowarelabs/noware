{
  "name": "nomo/sql",
  "version": "1.0.0",
  "description": "Core SQL construction DSL for nomo applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
