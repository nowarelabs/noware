{
  "name": "nomo",
  "version": "1.0.0",
  "private": true,
  "description": "nomo framework - production-grade TypeScript framework for Cloudflare Workers",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^0.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.2",
    "vite-plus": "latest",
    "vitest": "^4.0.0"
  }
}