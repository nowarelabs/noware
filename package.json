{
  "name": "nomo",
  "version": "0.0.0",
  "private": true,
  "description": "nomo framework - production-grade TypeScript framework for Cloudflare Workers",
  "type": "module",
  "scripts": {
    "publish": "node scripts/publish.js",
    "format:check": "oxlint --import --jsx --typescript --format",
    "format": "oxlint --import --jsx --typescript --format --write",
    "lint": "oxlint --import --jsx --typescript",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --build"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "oxlint": "^0.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.2",
    "vite-plus": "latest",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}